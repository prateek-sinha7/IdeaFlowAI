# ============================================================
# DEVELOPMENT (Personal Laptop — Anthropic API Key)
# ============================================================
# Uses your personal Anthropic API key for real Claude responses.
# PostgreSQL via Docker, Redis for caching.

ENV=development
AI_PROVIDER=anthropic

# Anthropic API (get your key from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE
ANTHROPIC_MODEL=claude-haiku-4-20250514

# Database (PostgreSQL via Docker)
DATABASE_URL=postgresql://ideaflow:password@localhost:5432/ideaflow

# Redis (via Docker)
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=dev-secret-change-this-to-random-string
ACCESS_TOKEN_EXPIRE_HOURS=24

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
