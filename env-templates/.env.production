# ============================================================
# PRODUCTION (AWS — Bedrock)
# ============================================================
# Uses AWS Bedrock for Claude access (no API key needed).
# Authenticates via IAM role (ECS task role) or AWS CLI profile.
# PostgreSQL on RDS, Redis on ElastiCache.

ENV=production
AI_PROVIDER=bedrock

# AWS Bedrock Configuration
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# For local testing with Bedrock, set your AWS profile:
# AWS_PROFILE=ideaflow-dev

# Database (RDS PostgreSQL)
DATABASE_URL=postgresql://ideaflow:STRONG_PASSWORD@ideaflow-db.xxxxx.us-east-1.rds.amazonaws.com:5432/ideaflow

# Redis (ElastiCache)
REDIS_URL=redis://ideaflow-cache.xxxxx.0001.use1.cache.amazonaws.com:6379

# Security (use AWS Secrets Manager in real production)
SECRET_KEY=GENERATE-A-64-CHAR-RANDOM-STRING-HERE
ACCESS_TOKEN_EXPIRE_HOURS=12

# CORS (your production domain)
CORS_ORIGINS=["https://ideaflow.yourdomain.com","https://www.ideaflow.yourdomain.com"]
